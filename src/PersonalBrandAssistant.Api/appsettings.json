{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "ApiKey": "pba-dev-key",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "AuditLog": {
    "RetentionDays": 90
  },
  "Retention": {
    "WorkflowTransitionLogDays": 180,
    "NotificationDays": 90
  },
  "AgentOrchestration": {
    "DailyBudget": 10.00,
    "MonthlyBudget": 100.00,
    "MaxRetries": 2,
    "PromptsPath": "prompts",
    "ExecutionTimeoutSeconds": 180,
    "LogPromptContent": false
  },
  "PlatformIntegrations": {
    "Twitter": {
      "CallbackUrl": "http://localhost:4200/platforms/twitter/callback",
      "BaseUrl": "https://api.x.com/2"
    },
    "LinkedIn": {
      "CallbackUrl": "http://localhost:4200/platforms/linkedin/callback",
      "ApiVersion": "202603",
      "BaseUrl": "https://api.linkedin.com/rest"
    },
    "Instagram": {
      "CallbackUrl": "http://localhost:4200/platforms/instagram/callback"
    },
    "YouTube": {
      "CallbackUrl": "http://localhost:4200/platforms/youtube/callback",
      "DailyQuotaLimit": 10000
    }
  },
  "MediaStorage": {
    "BasePath": "./media"
  },
  "Sidecar": {
    "WebSocketUrl": "ws://localhost:3001/ws",
    "ConnectionTimeoutSeconds": 30,
    "ReconnectDelaySeconds": 5
  },
  "ContentEngine": {
    "BrandVoiceScoreThreshold": 70,
    "MaxAutoRegenerateAttempts": 3,
    "EngagementRetentionDays": 30,
    "EngagementAggregationIntervalHours": 4,
    "MaxTreeDepth": 3,
    "SlotMaterializationDays": 7
  },
  "Firecrawl": {
    "BaseUrl": "http://192.168.50.10:3002/v1",
    "TimeoutSeconds": 60,
    "MaxContentLength": 50000
  },
  "TrendMonitoring": {
    "AggregationIntervalMinutes": 30,
    "TrendRadarApiUrl": "http://trendradar:8000/api",
    "FreshRssApiUrl": "http://freshrss:80/api",
    "RedditSubreddits": ["programming", "dotnet", "webdev"],
    "RelevanceScoreThreshold": 0.6,
    "MaxSuggestionsPerCycle": 10,
    "YouTube": { "Enabled": false },
    "EmailNewsletter": { "Enabled": false, "ImapServer": "", "Folder": "Newsletters" },
    "BrowserHistory": { "Enabled": false, "WebhookSecret": "" }
  },
  "AllowedHosts": "*"
}
